<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:CustomGarbageCollector.Models"
        xmlns:vm="using:CustomGarbageCollector.ViewModels"
        x:Class="CustomGarbageCollector.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Black Hole Garbage Collector"
        Width="800" Height="600"
        Background="#0B0B1A"> 
        
    <Grid RowDefinitions="Auto, *, Auto">
        
        <StackPanel 
            Grid.Row="0" 
            Orientation="Horizontal" 
            Spacing="15" 
            Margin="15" 
            HorizontalAlignment="Center"
        >
            <Button 
                Content="Spawn Planet" 
                Command="{Binding SpawnPlanet}" 
                Background="#2C3E50" 
                Foreground="White"
            />
            <Button 
                Content="Spawn Asteroid" 
                Command="{Binding SpawnAsteroid}" 
                Background="#2C3E50" Foreground="White"
            />
            <Button 
                Content="Mark as Garbage" 
                Command="{Binding MarkAsGarbage}" 
                Background="#D35400" 
                Foreground="White"
            />
            <Button 
                Content="Activate Black Hole (Sweep)" 
                Command="{Binding ActivateBlackHole}" 
                Background="#8E44AD" 
                Foreground="White" 
                FontWeight="Bold"
            />
        </StackPanel>

        <Grid Grid.Row="1" ClipToBounds="True">
            <Ellipse 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="200" 
                Height="200" 
                Fill="Transparent" 
                Stroke="#770000" 
                StrokeThickness="4"
                Opacity="0.3"
            />
            <Ellipse 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="175" 
                Height="175" 
                Fill="Transparent" 
                Stroke="#c74a00" 
                StrokeThickness="8"
                Opacity="0.7"
            />
            <Ellipse 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="156" 
                Height="156" 
                Fill="Transparent" 
                Stroke="#db904e" 
                StrokeThickness="4"
            />
            <Ellipse 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="150" 
                Height="150" 
                Fill="#111115" 
            />
            <TextBlock 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="Noir" 
                Foreground="#db904e" 
                FontWeight="Bold"
            />

            <ItemsControl ItemsSource="{Binding SpaceObjects}">
                
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SpaceObject">
                        <Ellipse 
                            Width="{Binding Size}" 
                            Height="{Binding Size}" 
                            Fill="{Binding ColorHex}">
                            
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="{Binding X}" Y="{Binding Y}" />
                            </Ellipse.RenderTransform>
                            
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                
            </ItemsControl>

        </Grid>

        <StackPanel Grid.Row="2" Margin="20">
            <TextBlock 
                Text="Singularity Distortion Level (Memory Usage)" 
                Foreground="#00FFFF" 
                Margin="0,0,0,5" 
                FontWeight="Bold"
            />
            
            <Border 
                Height="60"
                BorderBrush="#2C3E50" 
                BorderThickness="2"
                Background="#1A1A3A" 
            >
            <Path 
                Stroke="#FF0055"
                StrokeThickness="2"
                Data="{Binding GraphData}" 
            />
            </Border>
        </StackPanel>

    </Grid>
</Window>